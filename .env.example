# Copy to .env and adjust before running docker compose up.
# cp .env.example .env

# Session cookie signing secret (exactly 16, 24, or 32 characters).
SESSION_SECRET=change-me-32-char-secret-here!!

# Litestar debug mode (true/false).
DEBUG=false

# URL path prefix for the app (empty for local `uv run`; /weekmenu in Docker).
APP_BASE_PATH=/weekmenu

# Host port published for direct localhost access to the app container.
APP_PORT=8000

# PostgreSQL (required for Docker Compose).
POSTGRES_USER=weekmenu
POSTGRES_PASSWORD=change-me
POSTGRES_DB=weekmenu
DATABASE_URL=postgres://weekmenu:change-me@postgres:5432/weekmenu
