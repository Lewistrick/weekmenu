# Copy to .env and adjust before running docker compose up.
# cp .env.example .env

# Session cookie signing secret (use a long random string in production).
SESSION_SECRET=change-me-to-a-long-random-secret

# Litestar debug mode (true/false).
DEBUG=false

# Host port published for the app container.
APP_PORT=8000

# --- PostgreSQL (for future use; enable with: docker compose --profile postgres up) ---
# POSTGRES_USER=weekmenu
# POSTGRES_PASSWORD=change-me
# POSTGRES_DB=weekmenu
# DATABASE_URL=postgres://weekmenu:change-me@postgres:5432/weekmenu
